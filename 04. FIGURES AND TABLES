# helpers
fmt_mean_sd <- function(x) {
  sprintf("%.2f (%.2f)", mean(x, na.rm = TRUE), sd(x, na.rm = TRUE))
}

fmt_n_pct <- function(x, value) {
  n_valid <- sum(!is.na(x))
  n_value <- sum(as.character(x) == as.character(value), na.rm = TRUE)
  sprintf("%d (%.1f%%)", n_value, 100 * n_value / n_valid)
}

