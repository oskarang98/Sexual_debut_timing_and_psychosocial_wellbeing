# 1) Rubin-pooled avg_predictions helper

make_spline_curve_rubin <- function(model_list,
                                    age_grid,
                                    outcome_name,
                                    treat_var = "da_reported_or_assigned",
                                    vcov_type = "HC3",
                                    conf_level = 0.95) {

  M <- length(model_list)
  if (M < 1) stop("model_list is empty.", call. = FALSE)

  alpha <- 1 - conf_level
  zcrit <- stats::qnorm(1 - alpha / 2)

  pred_long <- purrr::map_dfr(
    seq_along(model_list),
    function(i) {

      m <- model_list[[i]]

      pred_i <- marginaleffects::avg_predictions(
        m,
        variables  = setNames(list(age_grid), treat_var),
        vcov       = vcov_type,
        conf_level = conf_level
      ) %>%
        dplyr::as_tibble()

      if (!(treat_var %in% names(pred_i))) {
        stop("avg_predictions() output did not contain treatment variable: ", treat_var, call. = FALSE)
      }
      if (!("estimate" %in% names(pred_i))) {
        stop("avg_predictions() output did not contain 'estimate'.", call. = FALSE)
      }

      if (!("std.error" %in% names(pred_i))) {
        if (all(c("conf.low", "conf.high") %in% names(pred_i))) {
          pred_i <- pred_i %>%
            mutate(std.error = (.data$conf.high - .data$conf.low) / (2 * zcrit))
        } else {
          stop(
            "avg_predictions() output missing 'std.error' and could not reconstruct it (no conf.low/conf.high).",
            call. = FALSE
          )
        }
      }

      pred_i %>%
        select(all_of(treat_var), estimate, std.error) %>%
        mutate(
          imp = i,
          var = (.data$std.error)^2
        )
    }
  )

  pooled <- pred_long %>%
    group_by(.data[[treat_var]]) %>%
    summarise(
      Q_bar  = mean(.data$estimate),
      U_bar  = mean(.data$var),
      B      = if (M > 1) stats::var(.data$estimate) else 0,
      T_var  = .data$U_bar + (1 + 1 / M) * .data$B,
      SE     = sqrt(.data$T_var),
      lambda = if_else(.data$T_var > 0 & .data$B > 0, ((1 + 1 / M) * .data$B) / .data$T_var, 0),
      df     = if_else(.data$T_var > 0 & .data$B > 0, (M - 1) / (.data$lambda^2), Inf),
      .groups = "drop"
    ) %>%
    mutate(
      t_crit    = stats::qt(1 - alpha / 2, df = .data$df),
      conf_low  = .data$Q_bar - .data$t_crit * .data$SE,
      conf_high = .data$Q_bar + .data$t_crit * .data$SE,
      outcome   = outcome_name
    ) %>%
    transmute(
      !!rlang::sym(treat_var) := .data[[treat_var]],
      estimate = .data$Q_bar,
      conf_low,
      conf_high,
      outcome
    )

  pooled
}

