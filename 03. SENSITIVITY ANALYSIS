# McDonald's omega computed on complete cases

omega_psych_complete_sens <- function(df, items, scale_name) {

  safe_omega <- purrr::possibly(
    function(dat_complete) psych::omega(dat_complete, nfactors = 1, plot = FALSE)$omega.tot,
    otherwise = NA_real_
  )

  dat <- df %>%
    dplyr::select(dplyr::all_of(items)) %>%
    tidyr::drop_na()

  k <- ncol(dat)
  N_used <- nrow(dat)

  tibble::tibble(
    scale = scale_name,
    n_items = k,
    N_used = N_used,
    omega_mc = safe_omega(dat)
  )
}

