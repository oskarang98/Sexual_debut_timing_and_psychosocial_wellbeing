effect_estimates_bin <- select(models_bin, starts_with("effect")) %>%
  pivot_longer(cols = starts_with("effect_"), names_to = "effect", values_to = "contrasts") %>%
  group_by(outcome, effect) %>%
  nest() %>%
  mutate(contrasts = map(.x = data, ~ summary(pool(.x$contrasts), conf.int = TRUE))) %>%
  select(contrasts) %>%
  unnest() %>%
  select(outcome, effect, contrast, estimate, `2.5 %`, `97.5 %`) %>%
  mutate(
    across(c(estimate, `2.5 %`, `97.5 %`),
           ~ ifelse(contrast == "18 - 14", (.x * -1) * 100, .x * 100)),
    contrast = factor(case_when(
      contrast == "18 - 14" ~ "Early (14y)",
      contrast == "22 - 18" ~ "Late (22y)",
      contrast == "25 - 18" ~ "Very late (25y)"
    )),
    estimation = case_when(
      str_detect(effect, "unadj") ~ "unadjusted",
      str_detect(effect, "iptw_adj") ~ "IPTW-adjusted",
      str_detect(effect, "iptw_women") ~ "IPTW-adjusted (Women)",
