effect_estimates_all <- rbind(effect_estimates_cont1, effect_estimates_bin) %>%
  mutate(
    outcome = factor(case_when(
      outcome == "dep_cms_t5" ~ "Depressive symptoms",
      outcome == "anx_cms_t5" ~ "Anxiety symptoms",
      outcome == "si_bin_t5" ~ "Suicidal ideation",
      outcome == "lon_cms_t5" ~ "Loneliness",
      outcome == "sa_cms_t5" ~ "Low social acceptance",
      outcome == "ss_cms_t5" ~ "Low social support",
      outcome == "se_cms_t5" ~ "Low self-esteem",
      outcome == "bi_cms_t5" ~ "Body dissatisfaction",
      outcome == "sd_cms_t5" ~ "Low sexual desire", #REMOVED POST HOC (SEE THE SUPPLEMENTARY MATERIALS P.3)
      outcome == "alc_t5" ~ "Problematic alcohol use",
      outcome == "drug_bin_t5" ~ "Illicit drug use",
      outcome == "smok_t5" ~ "Smoking"
    ),
    levels = c("Problematic alcohol use", "Illicit drug use", "Smoking",
               "Low sexual desire", "Body dissatisfaction", "Low self-esteem",
               "Loneliness", "Low social acceptance", "Low social support",
               "Depressive symptoms", "Anxiety symptoms", "Suicidal ideation"),
    ordered = TRUE),
    outcome_cat = factor(case_when(
      outcome %in% c("Depressive symptoms", "Anxiety symptoms", "Suicidal ideation") ~ "mental",
      outcome %in% c("Loneliness", "Low social acceptance", "Low social support") ~ "social",
      outcome %in% c("Low self-esteem", "Body dissatisfaction", "Low sexual desire") ~ "wb",
      outcome %in% c("Problematic alcohol use", "Illicit drug use", "Smoking") ~ "substance"
    ),
    levels = c("mental", "social", "wb", "substance"),
    ordered = TRUE),
    estimation = factor(
    estimation,
    levels = c("unadjusted", "IPTW-adjusted", "IPTW-adjusted (Women)", "IPTW-adjusted (Men)")
    ),
    tidy_estimate = paste0(
      formatC(round(estimate, 2), format = "f", digits = 2), " (",
      formatC(round(`2.5 %`, 2), format = "f", digits = 2), ", ",
      formatC(round(`97.5 %`, 2), format = "f", digits = 2), ")"
    )
  ) %>%
  ungroup()

# table output
