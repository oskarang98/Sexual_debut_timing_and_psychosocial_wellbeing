#### POMP SCALING ####
# Rescaling of continuous outcomes (0 to 100) based on theoretical minimum and maximum

pomp_specs_sens <- tibble(
  var = c(
    "dep_cms_t5", "anx_cms_t5",
    "lon_cms_t5", "sa_cms_t5", "ss_cms_t5",
    "se_cms_t5", "bi_cms_t5",
    "sd_cms_t5",
    "alc_t5"
  ),
  min = c(1, 1, 1, 1, 1, 1, 1, 1, 1),
  max = c(4, 4, 4, 4, 4, 4, 4, 6, 6)
)

# Apply a linear transformation that maps the theoretical minimum to 0 and maximum to 100
pomp_transform_sens <- function(x, min_val, max_val) {
  (x - min_val) / (max_val - min_val) * 100
}

darora_no_t1_sens <- darora_no_t1_sens %>%
  mutate(
    across(
      all_of(pomp_specs_sens$var),
      ~ pomp_transform_sens(
        .x,
        min_val = pomp_specs_sens %>% filter(var == cur_column()) %>% pull(min),
        max_val = pomp_specs_sens %>% filter(var == cur_column()) %>% pull(max)
      )
