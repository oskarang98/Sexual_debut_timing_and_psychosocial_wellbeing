for (i in seq_len(k)) {
  for (j in seq_len(k)) {
    if (i == j) {
      out_chr[i, j] <- "—"
    } else if (j < i) {
      out_chr[i, j] <- fmt_cell(r_mat[i, j], p_mat[i, j])
    } else {
      out_chr[i, j] <- ""
    }
  }
}

