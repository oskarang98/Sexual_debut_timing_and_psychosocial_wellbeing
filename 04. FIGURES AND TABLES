## 1) Rubin-pooled avg_predictions helper (gender-specific)

make_spline_curve_rubin_gender <- function(model_list,
                                           age_grid,
                                           outcome_name,
                                           treat_var   = "da_reported_or_assigned",
                                           gender_var  = "gender_t1",
                                           vcov_type   = "HC3",
                                           conf_level  = 0.95) {

  M <- length(model_list)
  if (M < 1) stop("model_list is empty.", call. = FALSE)

  alpha <- 1 - conf_level
  zcrit <- stats::qnorm(1 - alpha / 2)

  pred_long <- purrr::map_dfr(
    seq_along(model_list),
    function(i) {

      m  <- model_list[[i]]
      mf <- stats::model.frame(m)

      # Determine gender levels present in the model frame
      gvals <- mf[[gender_var]]
      if (is.factor(gvals)) {
        gvals <- levels(gvals)
      } else {
        gvals <- unique(as.character(gvals))
      }

      # Prefer canonical ordering if available
      gvals_lower <- tolower(as.character(gvals))
      if (all(c("women", "men") %in% gvals_lower)) {
        gvals <- c("women", "men")
      }

      grid_args <- list()
      grid_args[[treat_var]]  <- age_grid
      grid_args[[gender_var]] <- gvals

      newdata_cf <- do.call(
        marginaleffects::datagridcf,
        c(list(model = m), grid_args)
      )

      pred_i <- marginaleffects::avg_predictions(
        m,
        newdata    = newdata_cf,
        by         = c(treat_var, gender_var),
        vcov       = vcov_type,
        conf_level = conf_level
      ) %>%
        dplyr::as_tibble()

      # Required columns
      req_base <- c(treat_var, gender_var, "estimate")
      miss_base <- setdiff(req_base, names(pred_i))
      if (length(miss_base) > 0) {
        stop(
          "avg_predictions() output is missing required columns: ",
          paste(miss_base, collapse = ", "),
          call. = FALSE
        )
      }

         if (!("std.error" %in% names(pred_i))) {
        if (all(c("conf.low", "conf.high") %in% names(pred_i))) {
          pred_i <- pred_i %>%
            mutate(std.error = (.data$conf.high - .data$conf.low) / (2 * zcrit))
        } else {
          stop(
            "avg_predictions() output is missing 'std.error' and cannot reconstruct it ",
            "because 'conf.low'/'conf.high' are also missing.",
            call. = FALSE
          )
        }
      }

      pred_i %>%
        transmute(
          imp          = i,
          !!treat_var  := as.numeric(.data[[treat_var]]),
          !!gender_var := as.character(.data[[gender_var]]),
          estimate     = as.numeric(.data$estimate),
          var          = as.numeric(.data$std.error)^2
        )
    }
  )

  pooled <- pred_long %>%
    group_by(.data[[treat_var]], .data[[gender_var]]) %>%
    summarise(
      Q_bar  = mean(.data$estimate),
      U_bar  = mean(.data$var),
      B      = if (M > 1) stats::var(.data$estimate) else 0,
      T_var  = .data$U_bar + (1 + 1 / M) * .data$B,
      SE     = sqrt(.data$T_var),
      lambda = if_else(.data$T_var > 0 & .data$B > 0,
                       ((1 + 1 / M) * .data$B) / .data$T_var,
                       0),
      df     = if_else(.data$T_var > 0 & .data$B > 0,
                       (M - 1) / (.data$lambda^2),
                       Inf),
      .groups = "drop"
    ) %>%
    mutate(
      t_crit    = stats::qt(1 - alpha / 2, df = .data$df),
      conf_low  = .data$Q_bar - .data$t_crit * .data$SE,
      conf_high = .data$Q_bar + .data$t_crit * .data$SE,
      outcome   = outcome_name
    ) %>%
    transmute(
      !!rlang::sym(treat_var)  := .data[[treat_var]],
      !!rlang::sym(gender_var) := .data[[gender_var]],
      estimate = .data$Q_bar,
      conf_low,
      conf_high,
      outcome
    )

  pooled
}

