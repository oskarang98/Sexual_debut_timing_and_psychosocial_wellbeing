        if (all(!is.na(suppressWarnings(as.numeric(lev))))) {
          return(as.numeric(as.character(x)))
        } else {
          return(as.numeric(x))
        }
      }
      if (is.character(x)) {
        return(suppressWarnings(as.numeric(x)))
      }
      return(suppressWarnings(as.numeric(x)))
    }
  ))

