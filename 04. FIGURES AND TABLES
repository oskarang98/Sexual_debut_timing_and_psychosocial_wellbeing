# 4) Format into journal-style character matrix with stars
fmt_cell <- function(r, p) {
  if (is.na(r)) return("")
  
  stars <- dplyr::case_when(
    !is.na(p) && p < .05 ~ "*",
    TRUE ~ ""
  )
  
  paste0(sprintf("%.2f", r), stars)
}

k <- ncol(r_mat)
