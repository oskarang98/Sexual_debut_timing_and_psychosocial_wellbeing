base_forest <- function(dat, show_y = TRUE) {
  p <- ggplot(
    dat,
    aes(
      x = estimate,
      y = outcome,
      xmin = conf_low,
      xmax = conf_high,
      colour = contrast
    )
  ) +
    geom_vline(xintercept = 0, linetype = "dashed") +
    geom_point() +
    geom_errorbarh(height = 0) +
    scale_colour_manual(values = contrast_cols) +
    labs(x = x_lab, y = NULL) +
    theme_bw(base_family = "Times") +
    theme(
      legend.position = "none",
      panel.grid.major.y = element_blank(),
      panel.grid.minor = element_blank(),
      text = element_text(family = "Times", size = 10, colour = "black"),
      axis.text.x = element_text(family = "Times", size = 10, colour = "black"),
      axis.text.y = element_text(family = "Times", size = 10, colour = "black"),
      axis.title.x = element_text(family = "Times", size = 9, colour = "black"),
      axis.title.y = element_blank(),
      plot.title = element_text(hjust = 0.5, family = "Times", size = 10, colour = "black")
    )

  if (!show_y) {
    p <- p + theme(
      axis.text.y = element_blank(),
      axis.ticks.y = element_blank()
    )
  }

  p
}

make_domain_row <- function(dat, domain_title) {
  levs <- levels(dat$contrast)

  wrap_plots(
    map(
      seq_along(levs),
      \(i) base_forest(filter(dat, contrast == levs[i]), show_y = i == 1) +
        labs(title = levs[i])
    ),
    ncol = 3
  ) +
    plot_annotation(
      title = domain_title,
      theme = theme(
        text = element_text(family = "Times", colour = "black"),
        plot.title = element_text(
          hjust = 0.5,
          face = "bold",
          family = "Times",
          size = 12,
          colour = "black"
        )
      )
    )
}

