# Helper: mean score from item set with NaN set to missing
score_mean_from_items_sens <- function(df, items) {
  df %>%
    select(all_of(items)) %>%
    rowwise() %>%
    mutate(score = mean(c_across(everything()), na.rm = TRUE)) %>%
    ungroup() %>%
    transmute(score = na_if(score, NaN)) %>%
    pull(score)
}

