##### Deriving sexual debut age #####
# Apply wave-specific plausibility ranges and coalesce in the predefined priority order

yin_partici5_only <- yin_partici5_only %>%
  mutate(
    sexual_debut_t2 = if_else(between(as.numeric(SexEx2_5), 1, 22), as.numeric(SexEx2_5), NA_real_),
    sexual_debut_t3 = if_else(between(as.numeric(SexEx3_5), 1, 27), as.numeric(SexEx3_5), NA_real_),
    sexual_debut_t4 = if_else(between(as.numeric(SexEx4_5), 1, 33), as.numeric(SexEx4_5), NA_real_),
    sexual_debut_t5 = if_else(between(as.numeric(SexEx5_5), 1, 48), as.numeric(SexEx5_5), NA_real_),
    sexual_debut_age = coalesce(sexual_debut_t2, sexual_debut_t3, sexual_debut_t4, sexual_debut_t5)
  )

##### QC: Response distribution on SexEx5_4 among individuals with missing debut age #####
