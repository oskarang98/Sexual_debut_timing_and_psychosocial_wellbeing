##### Assigning debut age for individuals without reported debut who confirmed no debut at T5 #####
# Birth year is retrieved in the fixed priority order and converted to age in 2020

yin_partici5_only <- yin_partici5_only %>%
  mutate(
    birth_year_t5 = as.numeric(Birth5_3),
    birth_year_t4 = as.numeric(Birth4_3),
    birth_year_t3 = as.numeric(Birth3_3),
    assigned_debut_age = case_when(
      !is.na(birth_year_t5) ~ 2020 - birth_year_t5, #birth year reported as four digits (YYYY)
      is.na(birth_year_t5) & !is.na(birth_year_t4) ~ 120 - birth_year_t4, #birth year reported as two digits (YY)
      is.na(birth_year_t5) & is.na(birth_year_t4) & !is.na(birth_year_t3) ~ 120 - birth_year_t3, #birth year reported as two digits (YY)
      TRUE ~ NA_real_
    )
  )

