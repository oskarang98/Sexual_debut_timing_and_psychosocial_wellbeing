        data = .x,
        weightit = .y
      )
    ),
    effect_late_iptw_adj = map2(
      .x = model_iptw_adj, .y = data,
      ~ avg_comparisons(
        .x,
        newdata = .y,
        type = "response",
        variables = list(da_reported_or_assigned_sens = c(18, 22)),
